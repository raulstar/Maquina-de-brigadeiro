....................  
.................... unsigned int8 lcd_read_nibble(void) 
.................... { 
....................   #if (defined(LCD_DATA4) && defined(LCD_DATA5) && defined(LCD_DATA6) && defined(LCD_DATA7)) 
....................    unsigned int8 n = 0x00; 
....................  
....................    /* Read the data port */ 
....................    n |= input(LCD_DATA4); 
....................    n |= input(LCD_DATA5) << 1; 
....................    n |= input(LCD_DATA6) << 2; 
....................    n |= input(LCD_DATA7) << 3; 
....................     
....................    return(n); 
....................   #else 
....................    return(lcd.data); 
*
0328:  MOVF   08,W
0329:  MOVWF  77
032A:  SWAPF  08,W
032B:  ANDLW  0F
032C:  MOVWF  78
....................   #endif 
032D:  RETURN
.................... } 
....................  
.................... void lcd_send_nibble(unsigned int8 n) 
.................... { 
....................   #if (defined(LCD_DATA4) && defined(LCD_DATA5) && defined(LCD_DATA6) && defined(LCD_DATA7)) 
....................    /* Write to the data port */ 
....................    output_bit(LCD_DATA4, bit_test(n, 0)); 
....................    output_bit(LCD_DATA5, bit_test(n, 1)); 
....................    output_bit(LCD_DATA6, bit_test(n, 2)); 
....................    output_bit(LCD_DATA7, bit_test(n, 3)); 
....................   #else       
....................    lcdlat.data = n; 
*
031C:  SWAPF  62,W
031D:  ANDLW  F0
031E:  MOVWF  77
031F:  MOVLW  0F
0320:  ANDWF  08,W
0321:  IORWF  77,W
0322:  MOVWF  08
....................   #endif 
....................        
....................    delay_cycles(1); 
0323:  NOP
....................    lcd_output_enable(1); 
0324:  BSF    08.0
....................    delay_us(2); 
0325:  GOTO   326
....................    lcd_output_enable(0); 
0326:  BCF    08.0
0327:  RETURN
.................... } 
....................  
.................... void lcd_send_byte(unsigned int8 address, unsigned int8 n) 
.................... { 
....................   #if defined(__PCB__) 
....................    set_tris_lcd(LCD_OUTPUT_MAP); 
....................   #else 
....................    lcd_enable_tris(); 
*
032E:  BSF    03.5
032F:  BCF    08.0
....................    lcd_rs_tris(); 
0330:  BCF    08.1
....................    lcd_rw_tris(); 
0331:  BCF    08.2
....................   #endif 
....................  
....................    lcd_output_rs(0); 
0332:  BCF    03.5
0333:  BCF    08.1
....................    while ( bit_test(lcd_read_byte(),7) ) ; 
*
0355:  MOVF   78,W
0356:  MOVWF  61
0357:  BTFSC  61.7
0358:  GOTO   334
....................    lcd_output_rs(address); 
0359:  BTFSS  5F.0
035A:  BCF    08.1
035B:  BTFSC  5F.0
035C:  BSF    08.1
....................    delay_cycles(1); 
035D:  NOP
....................    lcd_output_rw(0); 
035E:  BCF    08.2
....................    delay_cycles(1); 
035F:  NOP
....................    lcd_output_enable(0); 
0360:  BCF    08.0
....................    lcd_send_nibble(n >> 4); 
0361:  SWAPF  60,W
0362:  MOVWF  61
0363:  MOVLW  0F
0364:  ANDWF  61,F
0365:  MOVF   61,W
0366:  MOVWF  62
0367:  CALL   31C
....................    lcd_send_nibble(n & 0xf); 
0368:  MOVF   60,W
0369:  ANDLW  0F
036A:  MOVWF  61
036B:  MOVWF  62
036C:  CALL   31C
036D:  RETURN
.................... } 
