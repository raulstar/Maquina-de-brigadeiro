.................... void lcd_gotoxy(unsigned int8 x, unsigned int8 y) 
.................... { 
....................    unsigned int8 address; 
....................     
....................    if(y!=1) 
03AC:  DECFSZ 5C,W
03AD:  GOTO   3AF
03AE:  GOTO   3B2
....................       address=LCD_LINE_TWO; 
03AF:  MOVLW  40
03B0:  MOVWF  5D
03B1:  GOTO   3B3
....................    else 
....................       address=0; 
03B2:  CLRF   5D
....................       
....................    address+=x-1; 
03B3:  MOVLW  01
03B4:  SUBWF  5B,W
03B5:  ADDWF  5D,F
....................    lcd_send_byte(0,0x80|address); 
03B6:  MOVF   5D,W
03B7:  IORLW  80
03B8:  MOVWF  5E
03B9:  CLRF   5F
03BA:  MOVF   5E,W
03BB:  MOVWF  60
03BC:  CALL   32E
....................  
....................   #if defined(LCD_EXTENDED_NEWLINE) 
03BD:  RETURN
....................    g_LcdX = x - 1; 
....................    g_LcdY = y - 1; 
....................   #endif 
